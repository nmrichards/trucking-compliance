# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://truckguard:truckguard@localhost:5432/truckguard

# ─── JWT Secrets (generate with: openssl rand -hex 64) ────────────────────────
JWT_ACCESS_SECRET=change-me-generate-with-openssl-rand-hex-64
JWT_REFRESH_SECRET=change-me-generate-with-openssl-rand-hex-64

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Dashboard: https://dashboard.stripe.com
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_ID=price_...           # $79/month recurring price ID
STRIPE_WEBHOOK_SECRET=whsec_...     # From: stripe listen --forward-to localhost:3001/api/stripe/webhook

# ─── App ──────────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:5173
PORT=3001
NODE_ENV=development
